DATABASE_URL="mysql://studytrace:studytrace@localhost:3306/studytrace"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES_IN="1d"
REFRESH_TOKEN_DAYS="30"
PORT="3000"
CORS_ORIGINS="https://studytrace.oykb.cn,https://api.studytrace.oykb.cn"

# AI proxy. BlueHeart uses https://api-ai.vivo.com.cn/v1/chat/completions by default.
BLUEHEART_API_KEY=""
BLUEHEART_APP_ID=""
BLUEHEART_BASE_URL="https://api-ai.vivo.com.cn/v1/chat/completions"
BLUEHEART_MODEL="Doubao-Seed-2.0-mini"
BLUEHEART_STREAM_IMAGE_MODE="ocr"
AI_DAILY_LIMIT="50"

# vivo gateway abilities. Keep endpoints aligned with docs/vivo_aigc_capabilities.md
# and backend/src/modules/ai/vivo-capabilities.ts.
VIVO_GATEWAY_BASE_URL="https://api-ai.vivo.com.cn"

# NLP / vision HTTP abilities.
VIVO_TRANSLATE_PATH="/translation/query/self"
VIVO_TRANSLATE_APP_NAME="studytrace"
VIVO_IMAGE_GENERATION_PATH="/api/v1/image_generation"
VIVO_IMAGE_SUBMIT_PATH="/api/v1/task_submit"
VIVO_IMAGE_QUERY_PATH="/api/v1/task_progress"
VIVO_IMAGE_BUSINESS_CODE="pc"
VIVO_IMAGE_STYLE_DEFAULT="7a0079b5571d5087825e52e26fc3518b"
VIVO_EMBEDDING_ENDPOINT=""
VIVO_VECTOR_MODEL="bge-base-zh-v1.5"
VIVO_POI_SEARCH_ENDPOINT=""
VIVO_REVERSE_GEOCODE_ENDPOINT=""
VIVO_POI_TOKEN=""

# Video generation task submit/query exposed as /ai/videos/tasks.
VIVO_VIDEO_MODEL="Doubao-Seedance-1.0-pro"
VIVO_VIDEO_SUBMIT_PATH="/api/v1/submit_task"
VIVO_VIDEO_QUERY_PATH="/api/v1/query_task"
VIVO_VIDEO_RATIO_DEFAULT="16:9"
VIVO_VIDEO_RESOLUTION_DEFAULT="720p"
VIVO_VIDEO_DURATION_DEFAULT="5"

# Speech abilities. The current /ai/speech/transcribe endpoint uses VIVO_ASR_ENDPOINT
# as an optional backend adapter; official realtime protocols are websocket-based.
VIVO_ASR_ENDPOINT=""
VIVO_ASR_ENGINE_ID=""
VIVO_ASR_WS_URL="ws://api-ai.vivo.com.cn/asr/v2"
VIVO_LONG_ASR_WS_URL="ws://asr-test-v2.vivo.com.cn/asr/v2"
VIVO_LASR_BASE_URL="https://api-ai.vivo.com.cn"
VIVO_DIALECT_ASR_WS_URL="ws://api-ai.vivo.com.cn/asr/v2"
VIVO_INTERPRETATION_WS_URL="ws://api-ai.vivo.com.cn/asr/v2"

# TTS and voice cloning are registered locally but require separate websocket /
# multipart integration before they can be exposed as StudyTrace APIs.
VIVO_TTS_WS_URL="wss://api-ai.vivo.com.cn/tts"
VIVO_TTS_ENGINE_ID="short_audio_synthesis_jovi"
VIVO_VOICE_CLONE_BASE_URL="https://api-ai.vivo.com.cn"
