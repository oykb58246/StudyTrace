DATABASE_URL="postgresql://studytrace:studytrace@localhost:5432/studytrace?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES_IN="1d"
REFRESH_TOKEN_DAYS="30"
PORT="3000"

# AI proxy. blueheart uses https://api-ai.vivo.com.cn/v1/chat/completions by default.
AI_PROVIDER="blueheart"
BLUEHEART_API_KEY=""
BLUEHEART_BASE_URL="https://api-ai.vivo.com.cn/v1/chat/completions"
BLUEHEART_MODEL="Volc-DeepSeek-V3.2"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"
AI_DAILY_LIMIT="50"
