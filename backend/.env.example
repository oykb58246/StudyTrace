DATABASE_URL="postgresql://studytrace:studytrace@localhost:5432/studytrace?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES_IN="1d"
REFRESH_TOKEN_DAYS="30"
PORT="3000"
CORS_ORIGINS="https://studytrace.oykb.cn,https://api.studytrace.oykb.cn"

# AI proxy. BlueHeart uses https://api-ai.vivo.com.cn/v1/chat/completions by default.
BLUEHEART_API_KEY=""
BLUEHEART_APP_ID=""
BLUEHEART_BASE_URL="https://api-ai.vivo.com.cn/v1/chat/completions"
BLUEHEART_MODEL="Doubao-Seed-2.0-mini"
BLUEHEART_STREAM_IMAGE_MODE="ocr"
AI_DAILY_LIMIT="50"

# vivo gateway abilities. Keep endpoints aligned with the competition documents.
VIVO_GATEWAY_BASE_URL="https://api-ai.vivo.com.cn"
VIVO_TRANSLATE_PATH="/translation/query/self"
VIVO_TRANSLATE_APP_NAME="studytrace"
VIVO_IMAGE_SUBMIT_PATH="/api/v1/task_submit"
VIVO_IMAGE_QUERY_PATH="/api/v1/task_progress"
VIVO_IMAGE_BUSINESS_CODE="pc"
VIVO_IMAGE_STYLE_DEFAULT="7a0079b5571d5087825e52e26fc3518b"
VIVO_ASR_ENDPOINT=""
VIVO_ASR_ENGINE_ID=""
VIVO_EMBEDDING_ENDPOINT=""
VIVO_VECTOR_MODEL=""
VIVO_POI_SEARCH_ENDPOINT=""
VIVO_REVERSE_GEOCODE_ENDPOINT=""
VIVO_POI_TOKEN=""
